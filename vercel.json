{
    "buildCommand": "npm run build",
    "outputDirectory": "dist/server",
    "framework": "vite",
    "env": {
        "NODE_ENV": "production"
    },
    "regions": [
        "iad1"
    ],
    "functions": {
        "dist/server/**": {
            "runtime": "nodejs20.x",
            "memory": 1024,
            "maxDuration": 60
        }
    }
}